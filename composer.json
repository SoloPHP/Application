{
  "name": "solophp/application",
  "description": "Application bootstrap with PSR-15 middleware pipeline",
  "keywords": ["application", "bootstrap", "middleware", "psr-15", "psr-7", "pipeline"],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Vitaliy Olos",
      "email": "vedastudio@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Solo\\Application\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Solo\\Application\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "psr/container": "^2.0",
    "psr/http-message": "^2.0",
    "psr/http-server-handler": "^1.0",
    "psr/http-server-middleware": "^1.0",
    "psr/http-factory": "^1.0",
    "solophp/contracts": "^1.0"
  },
  "suggest": {
    "solophp/container": "Default container implementation",
    "solophp/router": "Default router implementation",
    "solophp/http-emitter": "Default HTTP emitter implementation",
    "nyholm/psr7": "PSR-7/PSR-17 implementation",
    "nyholm/psr7-server": "ServerRequest creator from globals"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "squizlabs/php_codesniffer": "^4.0",
    "phpstan/phpstan": "^2.0",
    "solophp/container": "^2.1"
  },
  "scripts": {
    "test": "phpunit",
    "cs": "phpcs --standard=PSR12 src/ tests/",
    "cs-fix": "phpcbf --standard=PSR12 src/ tests/",
    "stan": "phpstan analyse src/ tests/",
    "check": [
      "@cs",
      "@stan",
      "@test"
    ]
  },
  "minimum-stability": "stable"
}
